# Environment Variables Template
# Copy this file to .env and replace placeholder values with real ones

# Google Gemini API Key
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model configuration
# Primary model used for requests
GEMINI_MODEL=gemini-2.5-flash-lite
# Comma-separated fallbacks tried automatically when quota/rate limits are hit
GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# Optional SQL generation cache controls
SQL_CACHE_TTL_SECONDS=86400
SQL_CACHE_MAX_ENTRIES=500

# Database Configuration
DATABASE_URL=sqlite:///database/sample.db

# Development Settings
FLASK_ENV=development

# Security (change in production)
JWT_SECRET_KEY=change-this-secret-key-in-production
